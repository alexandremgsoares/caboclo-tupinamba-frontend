# Headers para evitar cache no Netlify

# Página principal - NUNCA cachear
/
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# HTML files - não cachear
/*.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Service Worker - nunca cachear
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# RegisterSW - nunca cachear  
/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Manifest - pode ter cache curto
/manifest.webmanifest
  Cache-Control: public, max-age=300

# Assets estáticos - cache longo (têm hash no nome)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Imagens - cache médio
/*.png
  Cache-Control: public, max-age=86400

/*.jpg
  Cache-Control: public, max-age=86400
  
/*.jpeg
  Cache-Control: public, max-age=86400

/*.svg
  Cache-Control: public, max-age=86400

/*.webp
  Cache-Control: public, max-age=86400

# Página de limpeza de cache
/limpar-cache.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0